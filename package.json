{
    "private": true,
    "name": "pos-desktop",
    "version": "1.0.0",
    "description": "Electron Desktop App for Laravel POS System",
    "author": "POS Team",
    "main": "electron/main.js",
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "electron:start": "electron .",
        "electron:build": "electron-builder --win --x64",
        "launch": "node launcher.js"
    },
    "devDependencies": {
        "@popperjs/core": "^2.10.2",
        "axios": "^1.13.5",
        "bootstrap": "^5.1.3",
        "electron": "^41.2.0",
        "electron-builder": "^26.8.1",
        "laravel-mix": "^6.0.6",
        "lodash": "^4.17.19",
        "postcss": "^8.1.14",
        "resolve-url-loader": "^3.1.2",
        "sass": "^1.32.11",
        "sass-loader": "^11.0.1",
        "vue": "^2.6.12",
        "vue-loader": "^17.4.2",
        "vue-template-compiler": "^2.6.12"
    },
    "build": {
        "appId": "com.pos.desktop",
        "productName": "POS Desktop",
        "directories": {
            "output": "dist"
        },
        "files": [
            "electron/**/*"
        ],
        "win": {
            "target": [
                "dir"
            ]
        }
    }
}